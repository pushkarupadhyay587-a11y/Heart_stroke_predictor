{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/app.py"
    }
  ],
  "env": {
    "STREAMLIT_SERVER_HEADLESS": "true",
    "STREAMLIT_SERVER_ENABLECORS": "false",
    "STREAMLIT_BROWSER_SERVER_ADDRESS": "0.0.0.0",
    "STREAMLIT_SERVER_PORT": "8080"
  }
}
